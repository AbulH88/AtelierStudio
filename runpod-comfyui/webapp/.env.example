# Copy to .env (or export these) before running app.py

# --- Compute: local ComfyUI ---
# Local: http://127.0.0.1:8189 ; VPS: your tunnel URL e.g. https://comfy.thecristinaadam.com
LOCAL_COMFY_URL=http://127.0.0.1:8189

# Cloudflare Access service token (only on the VPS, to reach the protected tunnel)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# --- Compute: RunPod cloud (optional) ---
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=

# --- OpenRouter Vision (AI Description) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Reel library: Cloudflare R2 via Worker proxy ---
# (R2's S3 endpoint has a broken cert on this account; a Worker proxies the bucket)
R2_PROXY_URL=https://reels-proxy.<your-subdomain>.workers.dev
R2_PROXY_SECRET=

# Where ComfyUI lives (local start/stop buttons only; ignored on VPS)
COMFY_DIR=I:/@home/jimi/Documents/ComfyUI_V82
COMFY_BAT=Windows_Run_GPU.bat
