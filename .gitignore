# Python
__pycache__/
*.pyc

# Web app runtime / uploads
runpod-comfyui/webapp/frames/
runpod-comfyui/webapp/*.log

# Secrets (keep .env.example, ignore real env files)
.env
*.env
!*.env.example
runpod-comfyui/webapp/.env

# Auth store + session secret (runtime, never commit)
runpod-comfyui/webapp/users.json
runpod-comfyui/webapp/.secret
runpod-comfyui/webapp/ig_cookies.txt

# Home agent (contains the agent secret) + its log
runpod-comfyui/home_agent/Start_Agent.bat
runpod-comfyui/home_agent/agent.log

# OS
Thumbs.db
.DS_Store

# character catalog cache (fetched from ComfyUI)
runpod-comfyui/webapp/.catalog.json
